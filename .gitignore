# ============================================================================
#  Privacy guardrail — NEVER commit real financial data.
#  All CSV/JSON/TSV are ignored by default; only the specific bundled synthetic
#  examples are re-included, BY EXPLICIT NAME PATTERN. A real export dropped in
#  assets/ (e.g. assets/mybank.csv) does NOT match these and stays ignored.
# ============================================================================
*.csv
*.json
*.tsv

# Re-include ONLY the bundled synthetic examples + sample data
!assets/*.example.csv
!assets/*.example.json
!assets/sample_data/*_sample.csv

# Pipeline outputs (belt-and-suspenders; also covered by the rules above)
/canonical_transactions.csv
/master_transactions.csv
/Duplicate Audit.md
/networth-history.json
/finance-data.js
/Finance Dashboard*.html
/plaid_dump.json
/copilot_dump.json
inbox/
config/
outputs/
*.pdf

# Python / macOS cruft
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.DS_Store
